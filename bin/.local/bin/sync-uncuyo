#!/usr/bin/env zsh
# DESC: Sincroniza los archivos del directorio `uncuyo` con OneDrive UNCuyo

# Variables de entorno locales del script
LOCAL_LOG="$HOME/.sync-log-local.txt"
SYNCED_LOG="$HOME/uncuyo/.sync-log.txt"
# En laptop exo:
# REMOTE="UNCuyo:lcc"
# En laptop hp:
REMOTE="onedrive:lcc"
LOCAL_DIR="$HOME/uncuyo/"

# Funciones internas de log
log-local() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') | $1 | $(hostname) | SUCCESS" >> "$LOCAL_LOG"
}

log-synced() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') | $1 | $(hostname) | SUCCESS" >> "$SYNCED_LOG"
}

show_help() {
    echo "Usage: sync-uncuyo [subcommand] [rclone_options]"
    echo ""
    echo "Available subcommands:"
    echo "  up             Upload local files to the cloud"
    echo "  down           Download files from the cloud to the local machine"
    echo "  history        Show cloud upload history"
    echo "  history-local  Show full history of this machine"
    echo "  last           Show last cloud upload"
    echo "  last-local     Show last local activity"
    echo "  up-sim         Simulating Upload local files to the cloud"
    echo "  down-sim       Simulating Download local files to the cloud"
    echo "  status         show status"
    echo "  verify         Hace un diagnostico de verificacion de diferencias origen-destino (bidireccional)"
}

# Si no se pasan argumentos, mostramos la ayuda
if [[ -z "$1" ]]; then
    show_help
    exit 0
fi

SUBCOMMAND=$1
shift # Desplaza los argumentos para pasar el resto ($@) a rclone

case "$SUBCOMMAND" in
    up)
        # echo "▲ Uploading to OneDrive..."
        # echo "-> Uploading to OneDrive..."
        if [[ "$*" == *"--dry-run"* ]] || [[ "$*" == *"-n"* ]]; then
            echo "-> Uploading to OneDrive... (Simulation)"
            rclone sync "$LOCAL_DIR" "$REMOTE" --track-renames --create-empty-src-dirs --fast-list -v --progress "$@"
            echo "🔍 Dry-run - Not logged"
        else
            echo "-> Uploading to OneDrive..."
            if rclone sync "$LOCAL_DIR" "$REMOTE" --track-renames --create-empty-src-dirs --fast-list -v --progress "$@"; then
                log-local "UP"
                log-synced "UP"
                echo "[OK] Upload completed and logged"
            else
                echo "[FAIL] Upload error"
                exit 1
            fi
        fi
        ;;
        
    down)
        # echo "▼ Downloading from OneDrive..."
        if [[ "$*" == *"--dry-run"* ]] || [[ "$*" == *"-n"* ]]; then
            echo "<- Downloading from OneDrive... (Simulation)"
            rclone sync "$REMOTE" "$LOCAL_DIR" --track-renames --create-empty-src-dirs --fast-list -v --progress "$@"
            echo "🔍 Dry-run - Not logged"
        else
            echo "<- Downloading from OneDrive..."
            if rclone sync "$REMOTE" "$LOCAL_DIR" --track-renames --create-empty-src-dirs --fast-list -v --progress "$@"; then
                log-local "DOWN"
                echo "[OK] Download completed and logged locally"
            else
                echo "[FAIL] Download error"
                exit 1
            fi
        fi
        ;;

    history)
        echo "=== CLOUD UPLOAD HISTORY ==="
        [ -f "$SYNCED_LOG" ] && tail -n 30 "$SYNCED_LOG" || echo "No synchronized history yet"
        ;;

    history-local)
        echo "=== FULL LOCAL HISTORY ==="
        [ -f "$LOCAL_LOG" ] && tail -n 30 "$LOCAL_LOG" || echo "No local history yet"
        ;;

    last)
        echo "=== LAST CLOUD UPLOAD ==="
        [ -f "$SYNCED_LOG" ] && tail -n 1 "$SYNCED_LOG" || echo " No synchronized history yet"
        ;;

    last-local)
        echo "=== LAST ACTIVITY ON THIS MACHINE ==="
        [ -f "$LOCAL_LOG" ] && tail -n 1 "$LOCAL_LOG" || echo "No local history yet"
        ;;

    up-sim)
        # echo "=== Uploading to the OneDrive Simulation... ==="
        sync-uncuyo up --dry-run
        ;;

    down-sim)
        echo "=== Downloading from OneDrive Simulation... ==="
        sync-uncuyo down --dry-run
        ;;

    status)
        echo "=== STATUS UNCuyo ==="  && rclone check ~/uncuyo/ UNCuyo:lcc --track-renames --size-only --fast-list --retries 1 -q && echo "[OK] Todo sincronizado" || echo "[WARNING] Hay diferencias (usa verify)"
        ;;

    verify)
        echo "=== VERIFY UNCuyo ===" && rclone check ~/uncuyo/ UNCuyo:lcc --track-renames --size-only --fast-list -v && echo "[OK] Todo sincronizado" || echo "[WARNING] Hay diferencias"
        ;;

    *)
        echo "[ERROR] Unknown subcommand: $SUBCOMMAND"
        show_help
        exit 1
        ;;
esac

